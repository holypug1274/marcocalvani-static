{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/wp-content/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wp-content/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/en", "destination": "/en/index.html" },
    {
      "source": "/a-love-so-great",
      "destination": "/a-love-so-great/index.html"
    },
    {
      "source": "/everything-about-shapes-and-colors-this-season",
      "destination": "/everything-about-shapes-and-colors-this-season/index.html"
    }
  ]
}
